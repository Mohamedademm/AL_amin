generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  // "native" for local dev; "rhel-openssl-3.0.x" for the Vercel/AWS Lambda runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  ADMIN
  MANAGER
  WORKER
  CLIENT
}

enum OrderStatus {
  PENDING
  VERIFYING
  ACCEPTED
  SHIPPING
  DELIVERED
  REFUSED
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String
  firstName      String
  lastName       String
  phone          String?
  status         String       @default("ACTIVE")
  role           RoleName     @default(CLIENT)
  failedAttempts Int          @default(0)
  lockedUntil    DateTime?
  assignedSpotId String?
  assignedSpot   VendingSpot? @relation("AssignedStaff", fields: [assignedSpotId], references: [id])
  managedSpot    VendingSpot? @relation("ManagedSpot")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  orders        Order[]
  auditLogs      AuditLog[]
  eventsCreated  Event[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  products    Product[]
  discounts   Discount[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id               String        @id @default(uuid())
  name             String
  description      String?
  price            Decimal       @db.Decimal(10, 2)
  categoryId       String
  category         Category      @relation(fields: [categoryId], references: [id])
  imageUrl         String? // primary / thumbnail image
  images           ProductImage[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  inventory        Inventory[]
  orderItems       OrderItem[]
  discounts        Discount[]

  @@index([categoryId]) // catalog filtering / category joins
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId]) // load a product's gallery
}

model VendingSpot {
  id          String      @id @default(uuid())
  name        String
  location    String
  address     String
  phone       String?
  isWarehouse Boolean     @default(false) // the central warehouse (remote fulfilment)
  managerId    String?     @unique
  manager      User?      @relation("ManagedSpot", fields: [managerId], references: [id])
  inventory      Inventory[]
  orders         Order[]
  assignedStaff  User[]       @relation("AssignedStaff")
  createdAt      DateTime     @default(now())
  updatedAt   DateTime    @updatedAt
}

model Inventory {
  id         String      @id @default(uuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id])
  spotId     String
  spot       VendingSpot @relation(fields: [spotId], references: [id])
  quantity   Int         @default(0)
  updatedAt  DateTime    @updatedAt

  @@unique([productId, spotId])
  @@index([spotId]) // per-spot inventory listing (the composite covers productId only)
}

model Order {
  id           String      @id @default(uuid())
  clientId     String
  client       User        @relation(fields: [clientId], references: [id])
  spotId       String
  spot         VendingSpot @relation(fields: [spotId], references: [id])
  status       OrderStatus @default(PENDING)
  totalAmount  Decimal     @db.Decimal(10, 2)
  address      String
  phone        String
  fulfilment   String?     // LOCAL (nearest boutique) | REMOTE (central warehouse)
  etaDays      Int?        // estimated delivery in days (0 = immediate)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        OrderItem[]

  @@index([clientId]) // "my orders" lookups
  @@index([spotId]) // staff per-spot order lists
  @@index([status]) // dashboard / status filters
  @@index([createdAt]) // newest-first ordering at scale
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2) // Price at time of order

  @@index([orderId]) // load an order's lines
  @@index([productId]) // product sales lookups
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // e.g., "UPDATE_PRICE", "DISCOUNT_APPLIED"
  entity    String   // e.g., "Product"
  entityId  String
  oldValue  String?  @db.Text
  newValue  String?  @db.Text
  timestamp DateTime @default(now())

  @@index([userId]) // who-did-what lookups
  @@index([timestamp]) // newest-first audit feed
  @@index([entity, entityId]) // history of a specific record
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  createdBy   String
  user        User     @relation(fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Dynamic pricing rule applied to a whole category or a single product.
// `endsAt` and `maxQuantity` are "stealth" constraints — never exposed to clients.
model Discount {
  id          String    @id @default(uuid())
  percentage  Int       // percent off, e.g. 20 = -20%
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id])
  active      Boolean   @default(true)
  startsAt    DateTime  @default(now())
  endsAt      DateTime? // hidden from clients (stealth)
  maxQuantity Int?      // hidden from clients (stealth)
  createdAt   DateTime  @default(now())
}
