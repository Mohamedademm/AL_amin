# PostgreSQL connection string.
#
# RECOMMENDED — shared online Neon database (same data as production, no Docker):
#   Copy the connection string from https://console.neon.tech (your project →
#   Connect). Local dev uses the DIRECT string (host WITHOUT "-pooler");
#   Vercel/serverless uses the POOLED string (host WITH "-pooler").
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"
#
# ALTERNATIVE — local Docker Postgres (run `docker compose up -d` first):
# DATABASE_URL="postgresql://user:password@localhost:5433/alamin_db?schema=public"

# Secret used to sign JWT access tokens (use a long random value in production).
JWT_SECRET="change_this_to_a_long_random_secret"

# API server port (local only; Vercel sets this automatically).
PORT=5000

# Runtime environment: development | production
NODE_ENV=development

# Comma-separated list of allowed browser origins (CORS).
# Any *.vercel.app origin is also allowed automatically.
CLIENT_URL=http://localhost:5173

# Optional: max auth requests per 15 min window (brute-force throttle).
AUTH_RATE_LIMIT_MAX=100

# Optional — Google OAuth (leave blank to disable the "Sign in with Google" button).
# Create credentials at https://console.cloud.google.com → OAuth 2.0 Client ID.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
